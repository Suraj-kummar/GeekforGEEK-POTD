class Solution {
    void pushZerosToEnd(int[] arr) {
        int nonZeroIdx = 0; // Tracks where the next non-zero should go
        
        for (int i = 0; i < arr.length; i++) {
            if (arr[i] != 0) {
                // Swap arr[i] and arr[nonZeroIdx]
                int temp = arr[nonZeroIdx];
                arr[nonZeroIdx] = arr[i];
                arr[i] = temp;
                
                nonZeroIdx++;
            }
        }
    }
}